{
  "enabledPlugins": {
    "zero-project@zero-project": true
  },
  "extraKnownMarketplaces": {
    "zero-project": {
      "source": {
        "source": "directory",
        "path": ".claude/marketplace"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(./scripts/fetch-design.sh *)",
      "Bash(./scripts/detect-worktree.sh)",
      "Bash(./scripts/guard-branch-switch.sh)",
      "Bash(./scripts/guard-adb.sh)",
      "Bash(./scripts/emulator/acquire)",
      "Bash(./scripts/emulator/acquire *)",
      "Bash(./scripts/emulator/release)",
      "Bash(./scripts/emulator/release *)",
      "Bash(./scripts/emulator/start)",
      "Bash(./scripts/emulator/start *)",
      "Bash(./scripts/ui/*)",
      "Bash(./scripts/ui/adb *)",
      "Bash(./scripts/ui/dump-ui.sh)",
      "Bash(./scripts/ui/dump-ui.sh *)",
      "Bash(./scripts/ui/verify-screen.sh)",
      "Bash(./scripts/ui/verify-screen.sh *)",
      "Bash(./scripts/ui/screenshot.sh)",
      "Bash(./scripts/ui/screenshot.sh *)",
      "Bash(./scripts/install-app.sh)",
      "Bash(./scripts/run-android-tests.sh)",
      "Bash(./scripts/run-android-tests.sh *)",
      "Bash(./scripts/github/wait-for-ci.sh *)",
      "mcp__sentry__find_organizations",
      "mcp__sentry__search_issues",
      "mcp__sentry__get_sentry_resource"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/guard-branch-switch.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(gh *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/guard-branch-switch.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/guard-adb.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | { read -r p; echo \"$p\" | grep -q '/tmp/design-.*/chats/' && printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Blocked: chats/ in design archives are design iteration logs, not layout specs. Reading overflows context — read README and open_file only.\"}}'; } || true"
          }
        ]
      }
    ]
  }
}
