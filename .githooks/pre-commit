#!/bin/bash
protected_branch="master"
current_branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$current_branch" = "$protected_branch" ]; then
    echo "ERROR: Direct commit to $protected_branch is not allowed."
    exit 1
fi

# Block commits on feature branches in the main workspace.
# All feature work must happen in an isolated worktree.
git_dir=$(git rev-parse --git-dir 2>/dev/null)
git_dir=$(cd "$git_dir" && pwd -P)
common_dir=$(git rev-parse --git-common-dir 2>/dev/null)
common_dir=$(cd "$common_dir" && pwd -P)
if [ "$git_dir" = "$common_dir" ]; then
    echo "ERROR: Committing to a feature branch in the main workspace is not allowed."
    echo "Create a worktree first: git worktree add .worktrees/<name> -b <branch>"
    exit 1
fi

# Block committing build/ directories (generated artifacts)
staged_build_files=$(git diff --cached --name-only | grep -E '(^|/)build/')
if [ -n "$staged_build_files" ]; then
    echo "ERROR: Staged files include build/ artifacts:"
    echo "$staged_build_files"
    echo "Run 'git reset HEAD <file>' to unstage them."
    exit 1
fi

# Format staged files
echo "Running Spotless formatting..."
./gradlew spotlessApply

# Re-stage files that were modified by Spotless
# Use --diff-filter=d to only re-stage files that still exist on disk (exclude deleted files)
staged_files=$(git diff --cached --name-only --diff-filter=d)
if [ -n "$staged_files" ]; then
    echo "Re-staging formatted files..."
    git add $staged_files
fi

exit 0
