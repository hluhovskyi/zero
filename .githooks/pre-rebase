#!/bin/bash
# Block rebasing feature branches onto master.
# Use "git merge origin/master" instead — see docs/agents/branch-management.md.

upstream="$1"

case "$upstream" in
    master|origin/master|refs/heads/master|refs/remotes/origin/master)
        current_branch=$(git rev-parse --abbrev-ref HEAD)
        if [ "$current_branch" != "master" ]; then
            echo "ERROR: Rebasing onto master is not allowed on feature branches."
            echo "Use: git merge origin/master"
            echo "See: docs/agents/branch-management.md"
            exit 1
        fi
        ;;
esac

exit 0
